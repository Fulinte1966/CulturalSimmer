---
import { getCollection } from "astro:content";
import fs from "node:fs";
import path from "node:path";
import NewspaperLayout from "../../components/NewspaperLayout.astro";
import BookCover from "../../components/BookCover.astro";
import type { OutlineItem } from "../../lib/outline";
import {
  formatDisplayCallNumber,
  formatEditionDateString,
  formatShortVolume,
} from "../../lib/bookId";
import { getBookById } from "../../lib/books";
import { joinBasePath } from "../../lib/basePath";
import { getCalendarStatus } from "../../lib/uapis";
import "../../styles/book-detail.css";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({
    params: { id: book.data.id },
    props: { entry: book },
  }));
}

const { entry } = Astro.props;
const { id } = entry.data;
const { Content } = await entry.render();
const [book, calendar] = await Promise.all([
  getBookById(id),
  getCalendarStatus(),
]);

if (!book) {
  throw new Error(`Book metadata not found for ${id}`);
}

const { title, subtitle, author } = book;

let outline: OutlineItem[] = [];
try {
  const outlineAbsPath = path.join(
    process.cwd(),
    "src",
    "data",
    "outlines",
    `${id}_v${book.edition}.json`
  );
  outline = JSON.parse(fs.readFileSync(outlineAbsPath, "utf-8"));
} catch {
  outline = [];
}

const base = import.meta.env.BASE_URL;
const callNumber = formatDisplayCallNumber(book.parsed);
const tallyParams = new URLSearchParams({
  alignLeft: "1",
  transparentBackground: "1",
  dynamicHeight: "1",
  bookId: book.id,
  edition: String(book.edition),
});
const tallyEmbedUrl = `https://tally.so/embed/XxyDOP?${tallyParams.toString()}`;
const characterCount =
  (book.reading?.cjkCharacterCount ?? 0) +
  (book.reading?.latinTokenCount ?? 0);
const pageLabel = book.reading?.pageCount
  ? `${book.reading.pageCount} 页`
  : undefined;
const characterLabel = characterCount > 0
  ? `${(characterCount / 10000).toLocaleString("zh-CN", {
      maximumFractionDigits: 1,
      minimumFractionDigits: characterCount >= 10000 ? 1 : 0,
    })}${characterCount >= 10000 ? " 万" : ""}字`
  : undefined;
const fileSizeLabel = book.reading?.fileSizeBytes
  ? `${(book.reading.fileSizeBytes / 1024 / 1024).toLocaleString("zh-CN", {
      maximumFractionDigits: 2,
      minimumFractionDigits: 2,
    })} 兆字节`
  : undefined;
const volumeLabel = book.parsed.isVolume
  ? formatShortVolume(book.parsed.volumeNumber!, book.totalVolumes)
  : undefined;
const editionLabels =
  book.editions.length > 0
    ? book.editions.map((item) =>
        formatEditionDateString(item.editionDate, item.edition)
      )
    : [];
const description = `${title}${subtitle ? ` - ${subtitle}` : ""}${author ? `，${author}` : ""}。查看书目信息并下载 PDF。`;
---

<NewspaperLayout title={title} description={description} searchable>
  <main class="book-detail-page" data-pagefind-body>
    <div class="bd-grid" aria-hidden="true"></div>

    <article class="bd-frame">
      <header class="bd-head">
        <div class="bd-head-texture" aria-hidden="true"></div>
        <nav class="bd-breadcrumb" aria-label="面包屑">
          <a href={joinBasePath(base, "")}>主页</a>
          <span>・</span>
          <span>《{title}》{subtitle && `（${subtitle}）`}</span>
        </nav>

        <div class="bd-date-line">
          <img
            class="bd-cr"
            src={joinBasePath(base, "assets/brand/culturalsimmer-wordmark.svg")}
            alt=""
            width="35"
            height="18"
            aria-hidden="true"
          />
          <time>{calendar.dateLabel}</time>
          <span>{calendar.weekdayLabel}</span>
        </div>

      <button
        type="button"
        class="bd-proof"
        aria-label="勘误"
        aria-expanded="false"
        aria-controls="bd-errata-panel"
        data-errata-label-open="返回"
        data-errata-label-closed="勘误"
        data-errata-toggle
      >
        <img
          class="bd-proof-mark"
          src={joinBasePath(base, "assets/badges/badge-proof.svg")}
          alt=""
          width="48"
          height="67"
          aria-hidden="true"
        />
        <svg
          class="bd-proof-text"
          viewBox="0 0 26 24"
          width="26"
          height="24"
          aria-hidden="true"
          focusable="false"
        >
          <text class="bd-proof-text-under" x="13" y="12" text-anchor="middle" dominant-baseline="central" data-errata-toggle-text>勘误</text>
          <text class="bd-proof-text-front" x="13" y="12" text-anchor="middle" dominant-baseline="central" data-errata-toggle-text>勘误</text>
        </svg>
      </button>
      </header>

      <section class="bd-main">
        <div class="bd-cover-stage">
          <BookCover book={book} mode="model" pagefindMeta />
        </div>

        <section class="bd-text" aria-labelledby="book-title" data-errata-region>
          <div class="bd-text-content" data-book-detail-content>
          <div class="bd-info">
            <div class="bd-title-block">
              {book.series && <p class="bd-series">{book.series}</p>}
              <h1 id="book-title" class:list={{ "bd-title--long": title.length > 12 }} data-pagefind-meta="title">
                {title}
              </h1>
              {subtitle && (
                <p class="bd-subtitle" data-pagefind-meta="book_subtitle">
                  （{subtitle}）
                </p>
              )}
            </div>

            {author && <p class="bd-author" data-pagefind-meta="author">{author}</p>}

            <div class="bd-meta-ornament" aria-hidden="true">＊</div>

            <div class="bd-metrics" aria-label="书目元数据">
              {volumeLabel && <div class="bd-volume-row">{volumeLabel}</div>}
              <div class="bd-metrics-body">
                <div class="bd-stat-row">
                  {pageLabel && <span>{pageLabel}</span>}
                  {characterLabel && <span>{characterLabel}</span>}
                  {fileSizeLabel && <span>{fileSizeLabel}</span>}
                </div>
                <div
                  class:list={[
                    "bd-edition-row",
                    editionLabels.length === 1 && "bd-edition-row--single",
                    editionLabels.length > 1 && "bd-edition-row--grid",
                  ]}
                >
                  {editionLabels.map((label) => <span>{label}</span>)}
                </div>
              </div>
              <div class="bd-call-row">内部书号 {callNumber}</div>
            </div>
          </div>

          <div class="bd-actions" aria-label="书籍操作">
            <div class="bd-download" aria-label="传阅">
              <img
                class="bd-download-mark"
                src={joinBasePath(base, "assets/badges/badge-download.svg")}
                alt=""
                width="83"
                height="44"
                aria-hidden="true"
              />
              <span class="bd-download-label">传阅</span>
            </div>
            <div class="bd-secondary-actions">
              <a class="bd-button" href={joinBasePath(base, "books/")}>
                <span class="bd-button-dot" aria-hidden="true"></span>
                <span class="bd-button-text">基核技术站</span>
                <span class="bd-button-dot" aria-hidden="true"></span>
              </a>
              <a href={joinBasePath(base, `categories/${book.parsed.classification}/`)}>
                <span class="bd-button-dot" aria-hidden="true"></span>
                <span class="bd-button-text">择览资料站</span>
                <span class="bd-button-dot" aria-hidden="true"></span>
              </a>
            </div>
          </div>

          <div class="bd-rule" aria-hidden="true"></div>

          <div class="bd-intro">
            <section class="bd-abstract" aria-labelledby="summary-heading">
              <h2 id="summary-heading">内容提要</h2>
              <div class="bd-body">
                <Content />
              </div>
            </section>

            <section class="bd-outline" aria-labelledby="outline-heading">
              <h2 id="outline-heading">目录大纲</h2>
              {
                outline.length > 0 ? (
                  <ol class="bd-outline-list">
                    {outline.map((item) => (
                      <li class={`bd-outline-level-${item.level}`}>
                        <span>{item.title}</span>
                      </li>
                    ))}
                  </ol>
                ) : (
                  <p class="bd-empty">暂无目录数据</p>
                )
              }
            </section>
          </div>
          </div>

          <section
            id="bd-errata-panel"
            class="bd-errata-panel"
            aria-label="读者勘误表"
            data-errata-panel
            tabindex="-1"
            hidden
          >
            <iframe
              data-tally-src={tallyEmbedUrl}
              loading="lazy"
              width="100%"
              height="100"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              scrolling="no"
              title="读者勘误表"
            ></iframe>
          </section>
        </section>
      </section>
    </article>
  </main>
</NewspaperLayout>

<div hidden>
  <span data-pagefind-meta="book_id[id]">{id}</span>
  <span data-pagefind-meta={`call_number:${callNumber}`}></span>
  <span data-pagefind-meta={`cover_kind:${book.coverKind}`}></span>
</div>

<script>
  import "../../scripts/book-detail";
</script>
