---
import { getCollection } from "astro:content";
import fs from "node:fs";
import path from "node:path";
import Layout from "../../components/Layout.astro";
import BookCover from "../../components/BookCover.astro";
import BookMeta from "../../components/BookMeta.astro";
import Outline from "../../components/Outline.astro";
import type { OutlineItem } from "../../components/Outline.astro";
import { getBookById } from "../../lib/books";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({
    params: { id: book.data.id },
    props: { entry: book },
  }));
}

const { entry } = Astro.props;
const { id, title, edition, tags, author } = entry.data;
const titleParts = title.match(/^(.*?)(（[^）]+）)$/);
const titleMain = titleParts?.[1] ?? title;
const titleParenthetical = titleParts?.[2];
const { Content } = await entry.render();
const book = await getBookById(id);

if (!book) {
  throw new Error(`Book metadata not found for ${id}`);
}

let outline: OutlineItem[] = [];
try {
  const outlineAbsPath = path.join(
    process.cwd(),
    "src",
    "data",
    "outlines",
    `${id}_v${edition}.json`
  );
  outline = JSON.parse(fs.readFileSync(outlineAbsPath, "utf-8"));
} catch {
  outline = [];
}
---

<Layout
  title={title}
  description={`${title}${author ? `，${author}` : ""}。查看书目信息并下载 PDF。`}
  searchable
>
  <article class="book-detail" data-pagefind-body>
    <header class="detail-lead">
      <div class="detail-cover">
        <BookCover book={book} mode="model" pagefindMeta />
      </div>

      <div class="detail-intro">
        <p class="running-head">馆藏书目 / {id}</p>
        <h1
          class:list={{ "detail-title--long": title.length > 18 }}
          data-pagefind-meta="title"
        >
          {titleMain}
          {
            titleParenthetical && (
              <>
                <wbr />
                <span class="detail-title-parenthetical">
                  {titleParenthetical}
                </span>
              </>
            )
          }
        </h1>
        {author && <p class="detail-author">{author}</p>}
        <BookMeta book={book} />
      </div>
    </header>

    {
      tags.length > 0 && (
        <div class="tags detail-tags" aria-label="标签">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )
    }

    <section class="content-section" aria-labelledby="summary-heading">
      <h2 id="summary-heading">内容简介</h2>
      <div class="body">
        <Content />
      </div>
    </section>

    <Outline outline={outline} />
  </article>

</Layout>

<script>
  // Fix sub-pixel rendering gap between spine and cover on initial paint.
  // Double rAF: first frame completes initial paint + composite, second
  // frame re-sets the transform to force a fresh composite.  This handles
  // both soft (Ctrl+R) and hard (Ctrl+Shift+R) reloads.
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const model = document.querySelector(".book-cover--model");
      if (model) {
        const t = getComputedStyle(model).transform;
        model.style.transform = t;
      }
    });
  });
</script>
