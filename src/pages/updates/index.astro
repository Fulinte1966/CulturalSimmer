---
import Layout from "../../components/Layout.astro";
import { loadPublicUpdateFeed } from "../../lib/loadUpdateFeed";
import "../../styles/updates.css";

const feed = await loadPublicUpdateFeed();
const labels = {
  new_book: "新书上架",
  book_version: "版本更新",
  important_erratum: "重要勘误",
  site_announcement: "本站公告",
};
const date = (value: string) => new Intl.DateTimeFormat("zh-CN", {
  timeZone: "Asia/Shanghai",
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(new Date(value));
---

<Layout title="更新记录" description="文火电子书与网站更新记录。" activeNav="overview">
  <section class="updates-page" aria-labelledby="updates-title">
    <header class="updates-page-header">
      <h1 id="updates-title">更新记录</h1>
    </header>
    <ol class="updates-list">
      {feed.updates.map((update) => (
        <li id={update.id}>
          <div class="updates-meta">
            <time datetime={update.publishedAt}>{date(update.publishedAt)}</time>
            <span>［{labels[update.type]}］</span>
          </div>
          <h2><a href={update.url}>{update.bookId ? `${update.bookId}　` : ""}{update.title}</a></h2>
          {update.version && <p class="updates-version">{update.version}</p>}
          {update.summary.length > 0 && (
            <ul>{update.summary.map((item) => <li>{item}</li>)}</ul>
          )}
        </li>
      ))}
    </ol>
  </section>
</Layout>
