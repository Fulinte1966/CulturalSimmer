---
import { getCollection } from "astro:content";
import BookCover from "../components/BookCover.astro";
import NewspaperLayout from "../components/NewspaperLayout.astro";
import SiteUpdates from "../components/SiteUpdates.astro";
import { frontPageQuote } from "../data/front-page-quote";
import generatedUpdates from "../data/generated-updates.json";
import siteUpdatePins from "../data/site-update-pins.json";
import "../styles/home.css";
import { joinBasePath } from "../lib/basePath";
import { getAllBooks } from "../lib/books";
import { siteConfig } from "../lib/site";
import {
  buildSiteUpdates,
  splitSiteUpdates,
  type GeneratedSiteUpdate,
} from "../lib/siteUpdates";
import { getCalendarStatus, getWeatherStatus } from "../lib/uapis";

const [books, entries, announcements, calendar, weather] = await Promise.all([
  getAllBooks(),
  getCollection("books"),
  getCollection("announcements"),
  getCalendarStatus(),
  getWeatherStatus(),
]);

const base = import.meta.env.BASE_URL;
const leadBook = books.find((book) => book.id === "F0-1-1") ?? books[0];
const leadEntry = leadBook
  ? entries.find((entry) => entry.data.id === leadBook.id)
  : undefined;

const bookHref = leadBook
  ? joinBasePath(base, `books/${leadBook.id}/`)
  : undefined;
const shelfBooks = books.slice(0, 10);

const rawSummary =
  leadBook?.description ||
  leadEntry?.body?.trim() ||
  "";
const summaryParagraphs = rawSummary
  .replace(/\r\n/g, "\n")
  .split(/\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean)
  .slice(0, 4);

const siteUpdates = buildSiteUpdates(
  generatedUpdates as GeneratedSiteUpdate[],
  announcements,
  books
);
const siteUpdateGroups = splitSiteUpdates(siteUpdates, siteUpdatePins);

const quoteLabelChars = Array.from(frontPageQuote.label);
const quoteStyle = [
  `--fm-quote-compact-max-width:${frontPageQuote.compactMaxWidthPx}px`,
  `--fm-quote-max-width:${frontPageQuote.maxWidthPx}px`,
  `--fm-quote-text-align:${frontPageQuote.textAlign}`,
  `--fm-quote-regular-font-family:${frontPageQuote.typography.regular.fontFamily}`,
  `--fm-quote-regular-font-size:${frontPageQuote.typography.regular.fontSizePx}px`,
  `--fm-quote-regular-font-weight:${frontPageQuote.typography.regular.fontWeight}`,
  `--fm-quote-regular-letter-spacing:${frontPageQuote.typography.regular.letterSpacingPx}px`,
  `--fm-quote-regular-line-height:${frontPageQuote.typography.regular.lineHeightPx}px`,
  `--fm-quote-regular-padding-block:${frontPageQuote.typography.regular.paddingBlockPx}px`,
  `--fm-quote-regular-padding-inline:${frontPageQuote.typography.regular.paddingInlinePx}px`,
  `--fm-quote-compact-font-family:${frontPageQuote.typography.compact.fontFamily}`,
  `--fm-quote-compact-font-size:${frontPageQuote.typography.compact.fontSizePx}px`,
  `--fm-quote-compact-font-weight:${frontPageQuote.typography.compact.fontWeight}`,
  `--fm-quote-compact-letter-spacing:${frontPageQuote.typography.compact.letterSpacingPx}px`,
  `--fm-quote-compact-line-height:${frontPageQuote.typography.compact.lineHeightPx}px`,
  `--fm-quote-compact-padding-block:${frontPageQuote.typography.compact.paddingBlockPx}px`,
  `--fm-quote-compact-padding-inline:${frontPageQuote.typography.compact.paddingInlinePx}px`,
  `--fm-quote-regular-label-font-family:${frontPageQuote.labelTypography.regular.fontFamily}`,
  `--fm-quote-regular-label-font-weight:${frontPageQuote.labelTypography.regular.fontWeight}`,
  `--fm-quote-regular-label-max-font-size:${frontPageQuote.labelTypography.regular.maxFontSizePx}px`,
  `--fm-quote-regular-label-max-height:${frontPageQuote.labelTypography.regular.maxBlockHeightPx}px`,
  `--fm-quote-regular-label-width:${frontPageQuote.labelTypography.regular.widthPx}px`,
  `--fm-quote-regular-label-gap:${frontPageQuote.labelTypography.regular.gapPx}px`,
  `--fm-quote-regular-label-reserved:${frontPageQuote.labelTypography.regular.gapPx * 4}px`,
  `--fm-quote-regular-label-inset:${frontPageQuote.labelTypography.regular.insetBlockPx}px`,
  `--fm-quote-regular-label-offset-x:${frontPageQuote.labelTypography.regular.opticalOffsetXEm}em`,
  `--fm-quote-compact-label-font-family:${frontPageQuote.labelTypography.compact.fontFamily}`,
  `--fm-quote-compact-label-font-weight:${frontPageQuote.labelTypography.compact.fontWeight}`,
  `--fm-quote-compact-label-max-font-size:${frontPageQuote.labelTypography.compact.maxFontSizePx}px`,
  `--fm-quote-compact-label-max-height:${frontPageQuote.labelTypography.compact.maxBlockHeightPx}px`,
  `--fm-quote-compact-label-width:${frontPageQuote.labelTypography.compact.widthPx}px`,
  `--fm-quote-compact-label-gap:${frontPageQuote.labelTypography.compact.gapPx}px`,
  `--fm-quote-compact-label-reserved:${frontPageQuote.labelTypography.compact.gapPx * 4}px`,
  `--fm-quote-compact-label-inset:${frontPageQuote.labelTypography.compact.insetBlockPx}px`,
  `--fm-quote-compact-label-offset-x:${frontPageQuote.labelTypography.compact.opticalOffsetXEm}em`,
].join(";");

const weatherDayParts = (date?: string) => {
  if (!date) return { number: "--", unit: "日" };
  const parsed = new Date(`${date}T00:00:00+08:00`);
  return Number.isNaN(parsed.getTime())
    ? { number: "--", unit: "日" }
    : { number: String(parsed.getDate()), unit: "日" };
};

const weatherScaleParts = (value?: string | number) => {
  const text = String(value ?? "暂无");
  const match = text.match(/^(\d+(?:\.\d+)?)(.*)$/);
  return match ? { number: match[1], unit: match[2] || "级" } : { number: text, unit: "" };
};

const currentForecast = weather?.forecast?.[0];
const futureForecasts =
  weather?.forecast?.slice(1, 4).map((day) => ({
    ...weatherDayParts(day.date),
    weather: day.weather_day ?? day.weather_night ?? "暂无",
  })) ?? [
    { number: "--", unit: "日", weather: "暂无" },
    { number: "--", unit: "日", weather: "暂无" },
    { number: "--", unit: "日", weather: "暂无" },
  ];

const weatherCity = weather?.city ? `${weather.city}地区` : `${siteConfig.weatherCity}地区`;
const dayWeather = currentForecast?.weather_day ?? weather?.weather ?? "暂无";
const nightWeather = currentForecast?.weather_night ?? weather?.weather ?? "暂无";
const dayWindDir = currentForecast?.wind_dir_day ?? weather?.wind_direction ?? "暂无";
const dayWindScale = currentForecast?.wind_scale_day ?? weather?.wind_power ?? "暂无";
const nightWindDir = currentForecast?.wind_dir_night ?? weather?.wind_direction ?? "暂无";
const nightWindScale = currentForecast?.wind_scale_night ?? weather?.wind_power ?? "暂无";
const dayWindScaleParts = weatherScaleParts(dayWindScale);
const nightWindScaleParts = weatherScaleParts(nightWindScale);
const tempMax = currentForecast?.temp_max ?? weather?.temp_max ?? weather?.temperature ?? "—";
const tempMin = currentForecast?.temp_min ?? weather?.temp_min ?? weather?.temperature ?? "—";
---

<NewspaperLayout title="文火" description="文火电子书馆">
  <main class="figma-homepage" data-pagefind-ignore="all">
    <div class="fm-frame" aria-label="文火主页">
      <header class="fm-masthead">
        <section class="fm-logo-block" aria-label="报头">
          <img
            class="fm-wordmark"
            src={joinBasePath(base, "assets/brand/culturalsimmer-wordmark.svg")}
            alt="文火"
            width="228"
            height="115"
          />
          <div class="fm-date-line">
            <time>{calendar.dateLabel}</time>
            <span>{calendar.weekdayLabel}</span>
            {calendar.lunarLabel && <span class="fm-lunar">{calendar.lunarLabel}</span>}
          </div>
        </section>

        <div class="fm-quote-frame">
          <section class="fm-quote" aria-label="本期口号" style={quoteStyle}>
            <div class="fm-quote-label">
              {quoteLabelChars.map((char) => (
                <span class="fm-quote-label-block"><span class="fm-quote-label-glyph">{char}</span></span>
              ))}
            </div>
            <div class="fm-quote-copy heti">
              <p>
                {frontPageQuote.lines.map((line) => (
                  <span class="fm-quote-line">
                    <span>{line.text}</span>
                    {line.hangingPunctuation && (
                      <span class="fm-quote-hanging-punctuation">{line.hangingPunctuation}</span>
                    )}
                  </span>
                ))}
              </p>
            </div>
          </section>
        </div>
      </header>

      <div class="fm-thick-divider" aria-hidden="true"></div>

      <section class="fm-newsletter" aria-label="新书速递">
        <div class="fm-newsletter-viewport" tabindex="0" aria-label="横向浏览新书速递">
          <div class="fm-newsletter-track">
            <div class="fm-section-label" aria-hidden="true">
              <span>新书速递</span>
            </div>

            {leadBook && bookHref && (
            <div class="fm-detail">
              {leadBook.coverUrl && (
                <a class="fm-feature-cover" href={bookHref} aria-label={`查看《${leadBook.title}》`}>
                  <img
                    src={leadBook.coverUrl}
                    data-public-asset-fallback={leadBook.coverFallbackUrl}
                    alt={`《${leadBook.title}》封面`}
                  />
                </a>
              )}

              <div class="fm-vertical-rule" aria-hidden="true">
                <span>＊</span>
                <i></i>
                <span>＊</span>
              </div>

              <article class="fm-intro">
                <div class="fm-intro-head">
                  {leadBook.series && <p class="fm-series">{leadBook.series}</p>}
                  <h1 id="fm-lead-title">{leadBook.title}</h1>
                  {leadBook.subtitle && <p class="fm-subtitle">{leadBook.subtitle}</p>}
                </div>
                <div class="fm-intro-body heti">
                  {summaryParagraphs.map((paragraph) => <p>{paragraph}</p>)}
                </div>
              </article>
            </div>
            )}
          </div>
        </div>

        <SiteUpdates
          pinnedItems={siteUpdateGroups.pinnedItems}
          recentItems={siteUpdateGroups.recentItems}
          showDivider={siteUpdateGroups.showDivider}
          announcements={announcements}
        />
      </section>

      <div class="fm-midline" aria-hidden="true"></div>

      <section class="fm-book-shelf" aria-labelledby="fm-shelf-title">
        <div class="fm-book-shelf-track">
          <div class="fm-shelf-panel">
            <span class="fm-shelf-badge">上架书目</span>
            <a class="fm-shelf-button" id="fm-shelf-title" href={joinBasePath(base, "categories/")} aria-label="进入索引">
              <i aria-hidden="true">⁝</i>
              <span class="fm-shelf-button-text">索引</span>
              <i aria-hidden="true">⁝</i>
            </a>
          </div>
          <div class="fm-book-list-frame">
            <ol class="fm-book-list" aria-label="上架书目">
              {shelfBooks.map((book) => (
                <li>
                  <a href={joinBasePath(base, `books/${book.id}/`)} aria-label={`查看《${book.title}》`}>
                    <BookCover book={book} mode="flat" />
                  </a>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

      <div class="fm-bottom-divider" aria-hidden="true"></div>

      <footer class="fm-contact">
        <div class="fm-address">
          <span class="fm-address-line fm-address-domestic">
            <span>本报地址：国内 霹雳放映站・</span>
            <a href="https://space.bilibili.com/3494350898072545" target="_blank" rel="noreferrer">走火放映室</a>
          </span>
          <span class="fm-address-line fm-address-overseas">
            <span>国外 优博放映站・</span>
            <a href="https://www.youtube.com/@Fulinte1966" target="_blank" rel="noreferrer">弗林特放映室</a>
          </span>
        </div>
        <span class="fm-footer-rule" aria-hidden="true"></span>
        <div class="fm-weather" data-weather-city={siteConfig.weatherCity}>
          <div class="fm-weather-labels">
            <p><span data-weather-field="city">{weatherCity}</span></p>
            <p>天气预报</p>
          </div>
          <div class="fm-weather-detail">
            <p class="fm-weather-item fm-weather-item--condition">
              <span class="fm-weather-key">白天</span>
              <span class="fm-weather-value" data-weather-field="dayWeather">{dayWeather}</span>
            </p>
            <p class="fm-weather-item fm-weather-item--direction">
              <span class="fm-weather-key">风向</span>
              <span class="fm-weather-value" data-weather-field="dayWindDir">{dayWindDir}</span>
            </p>
            <p class="fm-weather-item fm-weather-item--scale">
              <span class="fm-weather-key">风力</span>
              <span class="fm-weather-value" data-weather-field="dayWindScale"><span class="fm-weather-number" data-weather-number>{dayWindScaleParts.number}</span><span data-weather-unit>{dayWindScaleParts.unit}</span></span>
            </p>
            <p class="fm-weather-item fm-weather-item--temperature">
              <strong class="fm-weather-key">最高温度</strong>
              <span class="fm-weather-value"><span class="fm-weather-number" data-weather-field="tempMax">{tempMax}</span>度</span>
            </p>
            <p class="fm-weather-item fm-weather-item--condition">
              <span class="fm-weather-key">夜间</span>
              <span class="fm-weather-value" data-weather-field="nightWeather">{nightWeather}</span>
            </p>
            <p class="fm-weather-item fm-weather-item--direction">
              <span class="fm-weather-key">风向</span>
              <span class="fm-weather-value" data-weather-field="nightWindDir">{nightWindDir}</span>
            </p>
            <p class="fm-weather-item fm-weather-item--scale">
              <span class="fm-weather-key">风力</span>
              <span class="fm-weather-value" data-weather-field="nightWindScale"><span class="fm-weather-number" data-weather-number>{nightWindScaleParts.number}</span><span data-weather-unit>{nightWindScaleParts.unit}</span></span>
            </p>
            <p class="fm-weather-item fm-weather-item--temperature">
              <strong class="fm-weather-key">最低温度</strong>
              <span class="fm-weather-value"><span class="fm-weather-number" data-weather-field="tempMin">{tempMin}</span>度</span>
            </p>
          </div>
          <div class="fm-weather-days">
            {futureForecasts.map((day, index) => (
              <p>
                <span data-weather-day={index}><span class="fm-weather-number" data-weather-day-number>{day.number}</span><span data-weather-day-unit>{day.unit}</span></span>
                <br />
                <span data-weather-forecast={index}>{day.weather}</span>
              </p>
            ))}
          </div>
        </div>
      </footer>
    </div>
  </main>
</NewspaperLayout>

<script>
  import "../scripts/home-shelf";
  import "../scripts/home-weather";
</script>
