---
import { getCollection } from "astro:content";
import BookCover from "../components/BookCover.astro";
import NewspaperLayout from "../components/NewspaperLayout.astro";
import SiteUpdates from "../components/SiteUpdates.astro";
import generatedUpdates from "../data/generated-updates.json";
import siteUpdatePins from "../data/site-update-pins.json";
import "../styles/home.css";
import { joinBasePath } from "../lib/basePath";
import { getAllBooks } from "../lib/books";
import { siteConfig } from "../lib/site";
import {
  buildSiteUpdates,
  splitSiteUpdates,
  type GeneratedSiteUpdate,
} from "../lib/siteUpdates";
import { getCalendarStatus, getWeatherStatus } from "../lib/uapis";

const [books, entries, announcements, calendar, weather] = await Promise.all([
  getAllBooks(),
  getCollection("books"),
  getCollection("announcements"),
  getCalendarStatus(),
  getWeatherStatus(),
]);

const base = import.meta.env.BASE_URL;
const leadBook = books.find((book) => book.id === "F0-1-1") ?? books[0];
const leadEntry = leadBook
  ? entries.find((entry) => entry.data.id === leadBook.id)
  : undefined;

const bookHref = leadBook
  ? joinBasePath(base, `books/${leadBook.id}/`)
  : undefined;
const shelfBooks = books.slice(0, 10);

const rawSummary =
  leadBook?.description ||
  leadEntry?.body?.trim() ||
  "";
const summaryParagraphs = rawSummary
  .replace(/\r\n/g, "\n")
  .split(/\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean)
  .slice(0, 4);

const siteUpdates = buildSiteUpdates(
  generatedUpdates as GeneratedSiteUpdate[],
  announcements,
  books
);
const siteUpdateGroups = splitSiteUpdates(siteUpdates, siteUpdatePins);

const quoteLines =
  siteConfig.frontPageSlogan?.length > 0
    ? siteConfig.frontPageSlogan
    : ["你们要关心国家大事", "要把无产阶级文化大革命", "进行到底！"];
const quoteLabelChars = Array.from("毛主席语录");

const weatherDayParts = (date?: string) => {
  if (!date) return { number: "--", unit: "日" };
  const parsed = new Date(`${date}T00:00:00+08:00`);
  return Number.isNaN(parsed.getTime())
    ? { number: "--", unit: "日" }
    : { number: String(parsed.getDate()), unit: "日" };
};

const weatherScaleParts = (value?: string | number) => {
  const text = String(value ?? "暂无");
  const match = text.match(/^(\d+(?:\.\d+)?)(.*)$/);
  return match ? { number: match[1], unit: match[2] || "级" } : { number: text, unit: "" };
};

const currentForecast = weather?.forecast?.[0];
const futureForecasts =
  weather?.forecast?.slice(1, 4).map((day) => ({
    ...weatherDayParts(day.date),
    weather: day.weather_day ?? day.weather_night ?? "暂无",
  })) ?? [
    { number: "--", unit: "日", weather: "暂无" },
    { number: "--", unit: "日", weather: "暂无" },
    { number: "--", unit: "日", weather: "暂无" },
  ];

const weatherCity = weather?.city ? `${weather.city}地区` : `${siteConfig.weatherCity}地区`;
const dayWeather = currentForecast?.weather_day ?? weather?.weather ?? "暂无";
const nightWeather = currentForecast?.weather_night ?? weather?.weather ?? "暂无";
const dayWindDir = currentForecast?.wind_dir_day ?? weather?.wind_direction ?? "暂无";
const dayWindScale = currentForecast?.wind_scale_day ?? weather?.wind_power ?? "暂无";
const nightWindDir = currentForecast?.wind_dir_night ?? weather?.wind_direction ?? "暂无";
const nightWindScale = currentForecast?.wind_scale_night ?? weather?.wind_power ?? "暂无";
const dayWindScaleParts = weatherScaleParts(dayWindScale);
const nightWindScaleParts = weatherScaleParts(nightWindScale);
const tempMax = currentForecast?.temp_max ?? weather?.temp_max ?? weather?.temperature ?? "—";
const tempMin = currentForecast?.temp_min ?? weather?.temp_min ?? weather?.temperature ?? "—";
---

<NewspaperLayout title="文火" description="文火电子书馆">
  <main class="figma-homepage" data-pagefind-ignore="all">
    <div class="fm-frame" aria-label="文火主页">
      <header class="fm-masthead">
        <section class="fm-logo-block" aria-label="报头">
          <img
            class="fm-wordmark"
            src={joinBasePath(base, "assets/brand/culturalsimmer-wordmark.svg")}
            alt="文火"
            width="228"
            height="115"
          />
          <div class="fm-date-line">
            <time>{calendar.dateLabel}</time>
            <span>{calendar.weekdayLabel}</span>
            {calendar.lunarLabel && <span class="fm-lunar">{calendar.lunarLabel}</span>}
          </div>
        </section>

        <section class="fm-quote" aria-label="本期口号">
          <div class="fm-quote-label">
            {quoteLabelChars.map((char) => <span>{char}</span>)}
          </div>
          <div class="fm-quote-copy">
            <p>
              {quoteLines.map((line, index) => (
                <>
                  <span>{index === 0 ? `　　${line}` : line}</span>
                  {index < quoteLines.length - 1 && <br />}
                </>
              ))}
            </p>
          </div>
        </section>
      </header>

      <div class="fm-thick-divider" aria-hidden="true"></div>

      <section class="fm-newsletter" aria-label="新书速递">
        <div class="fm-section-label" aria-hidden="true">
          <span>新书速递</span>
        </div>

        {leadBook && bookHref && (
        <div class="fm-detail">
          {leadBook.coverUrl && (
            <a class="fm-feature-cover" href={bookHref} aria-label={`查看《${leadBook.title}》`}>
              <img src={leadBook.coverUrl} alt={`《${leadBook.title}》封面`} />
            </a>
          )}

          <div class="fm-vertical-rule" aria-hidden="true">
            <span>＊</span>
            <i></i>
            <span>＊</span>
          </div>

          <article class="fm-intro">
            <div class="fm-intro-head">
              {leadBook.series && <p class="fm-series">{leadBook.series}</p>}
              <h1 id="fm-lead-title">{leadBook.title}</h1>
              {leadBook.subtitle && <p class="fm-subtitle">{leadBook.subtitle}</p>}
            </div>
            <div class="fm-intro-body">
              {summaryParagraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </article>

          <SiteUpdates
            pinnedItems={siteUpdateGroups.pinnedItems}
            recentItems={siteUpdateGroups.recentItems}
            showDivider={siteUpdateGroups.showDivider}
            announcements={announcements}
          />
        </div>
        )}
      </section>

      <div class="fm-midline" aria-hidden="true"></div>

      <section class="fm-book-shelf" aria-labelledby="fm-shelf-title">
        <div class="fm-shelf-panel">
          <span class="fm-shelf-badge">上架书目</span>
          <a class="fm-shelf-button" id="fm-shelf-title" href={joinBasePath(base, "categories/")} aria-label="进入索引">
            <i aria-hidden="true">⁝</i>
            <span class="fm-shelf-button-text">索引</span>
            <i aria-hidden="true">⁝</i>
          </a>
        </div>
        <div class="fm-book-list-frame">
        <ol class="fm-book-list" aria-label="上架书目">
          {shelfBooks.map((book) => (
            <li>
              <a href={joinBasePath(base, `books/${book.id}/`)} aria-label={`查看《${book.title}》`}>
                <BookCover book={book} mode="flat" />
              </a>
            </li>
          ))}
        </ol>
        </div>
      </section>

      <div class="fm-bottom-divider" aria-hidden="true"></div>

      <footer class="fm-contact">
        <div class="fm-address">
          <span>本报地址：国内　霹雳放映站・</span>
          <a href="https://space.bilibili.com/3494350898072545" target="_blank" rel="noreferrer">走火放映室</a>
          <span class="fm-address-overseas">国外　优博放映站・</span>
          <a href="https://www.youtube.com/@Fulinte1966" target="_blank" rel="noreferrer">弗林特放映室</a>
        </div>
        <span class="fm-footer-rule" aria-hidden="true"></span>
        <div class="fm-weather" data-weather-city={siteConfig.weatherCity}>
          <div class="fm-weather-labels">
            <p><span data-weather-field="city">{weatherCity}</span></p>
            <p>天气预报</p>
          </div>
          <div class="fm-weather-detail">
            <p>白天 <span data-weather-field="dayWeather">{dayWeather}</span></p>
            <p>风向 <span data-weather-field="dayWindDir">{dayWindDir}</span></p>
            <p>风力 <span data-weather-field="dayWindScale"><span class="fm-weather-number" data-weather-number>{dayWindScaleParts.number}</span><span data-weather-unit>{dayWindScaleParts.unit}</span></span></p>
            <p><strong>最高温度</strong> <span class="fm-weather-number" data-weather-field="tempMax">{tempMax}</span>度</p>
            <p>夜间 <span data-weather-field="nightWeather">{nightWeather}</span></p>
            <p>风向 <span data-weather-field="nightWindDir">{nightWindDir}</span></p>
            <p>风力 <span data-weather-field="nightWindScale"><span class="fm-weather-number" data-weather-number>{nightWindScaleParts.number}</span><span data-weather-unit>{nightWindScaleParts.unit}</span></span></p>
            <p><strong>最低温度</strong> <span class="fm-weather-number" data-weather-field="tempMin">{tempMin}</span>度</p>
          </div>
          <div class="fm-weather-days">
            {futureForecasts.map((day, index) => (
              <p>
                <span data-weather-day={index}><span class="fm-weather-number" data-weather-day-number>{day.number}</span><span data-weather-day-unit>{day.unit}</span></span>
                <br />
                <span data-weather-forecast={index}>{day.weather}</span>
              </p>
            ))}
          </div>
        </div>
      </footer>
    </div>
  </main>
</NewspaperLayout>

<script>
  import "../scripts/home-shelf";
  import "../scripts/home-weather";
</script>
