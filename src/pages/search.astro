---
import Layout from "../components/Layout.astro";
---

<Layout
  title="馆藏检索"
  description="检索电子书馆的书名、作者、索书号、标签、简介与目录。"
>
  <header class="page-header search-header">
    <div>
      <h1>馆藏检索</h1>
      <p>检索书名、作者、索书号、标签、内容简介与目录。</p>
    </div>
    <p class="folio">全文索引</p>
  </header>

  <div class="search-container">
    <div id="search"></div>
    <noscript>
      <p>搜索需要启用 JavaScript。</p>
    </noscript>
  </div>
</Layout>

<script>
  const base = import.meta.env.BASE_URL;

  async function loadPagefind() {
    try {
      const cssLink = document.createElement("link");
      cssLink.href = `${base}/pagefind/pagefind-ui.css`;
      cssLink.rel = "stylesheet";
      document.head.appendChild(cssLink);

      const script = document.createElement("script");
      script.src = `${base}/pagefind/pagefind-ui.js`;
      script.onload = () => {
        const searchEl = document.getElementById("search");
        if (searchEl && window.PagefindUI) {
          const pagefind = new window.PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: true,
          });
          const query = new URLSearchParams(window.location.search)
            .get("q")
            ?.trim();
          if (query) {
            pagefind.triggerSearch(query);
          }
        }
      };
      document.head.appendChild(script);
    } catch {
      // Pagefind is only available after a production build.
    }
  }

  loadPagefind();
</script>
