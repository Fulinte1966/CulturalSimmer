---
import Layout from "../components/Layout.astro";
---

<Layout title="搜索">
  <h1 class="page-heading">搜索</h1>
  <div class="search-container">
    <div id="search"></div>
    <noscript>
      <p>搜索需要启用 JavaScript。</p>
    </noscript>
  </div>
</Layout>

<script>
  // Pagefind UI is generated by `pagefind --site dist` after build.
  // In dev mode (astro dev), search won't work — that's expected.
  const base = import.meta.env.BASE_URL;

  async function loadPagefind() {
    try {
      const cssLink = document.createElement("link");
      cssLink.href = `${base}/pagefind/pagefind-ui.css`;
      cssLink.rel = "stylesheet";
      document.head.appendChild(cssLink);

      const script = document.createElement("script");
      script.src = `${base}/pagefind/pagefind-ui.js`;
      script.onload = () => {
        const searchEl = document.getElementById("search");
        if (searchEl && window.PagefindUI) {
          new window.PagefindUI({
            element: "#search",
            showSubResults: true,
          });
        }
      };
      document.head.appendChild(script);
    } catch {
      // Pagefind not available (e.g. in dev mode)
    }
  }

  loadPagefind();
</script>
