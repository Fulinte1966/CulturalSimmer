---
import NewspaperLayout from "../../components/NewspaperLayout.astro";
import BookCover from "../../components/BookCover.astro";
import { getBookById } from "../../lib/books";
import "../../styles/book-model-debug.css";

const book = await getBookById("F0-1-1");

if (!book) {
  throw new Error("Debug book F0-1-1 was not found.");
}
---

<NewspaperLayout title="书模调试台" description="独立书模几何参数调试页面">
  <main class="book-model-debug">
    <section class="bmd-workbench" aria-label="书模预览">
      <div class="bmd-stage-shell">
        <div class="bmd-axis" aria-hidden="true"></div>
        <div class="bmd-cover-stage" data-debug-stage>
          <BookCover book={book} mode="model" />
        </div>
      </div>
    </section>

    <aside class="bmd-controls" aria-label="调试参数">
      <header class="bmd-controls-head">
        <div>
          <p class="bmd-kicker">Book model lab</p>
          <h1>书模调试台</h1>
        </div>
        <div class="bmd-actions">
          <button type="button" data-action="reset">重置</button>
          <button type="button" data-action="copy">复制参数</button>
        </div>
      </header>

      <div class="bmd-groups" data-controls></div>

      <section class="bmd-output" aria-label="当前 CSS 参数">
        <div class="bmd-output-head">
          <h2>当前参数</h2>
          <button type="button" data-action="clear">清除本地保存</button>
        </div>
        <textarea data-output rows="13" spellcheck="false" readonly></textarea>
        <p data-status class="bmd-status" role="status" aria-live="polite">
          参数会自动保存在本机浏览器。
        </p>
      </section>
    </aside>
  </main>

  <script>
    type ControlConfig = {
      key: string;
      label: string;
      unit: string;
      min: number;
      max: number;
      step: number;
      value: number;
      target: "model" | "stage";
      cssVar: string;
    };

    const storageKey = "cultural-simmer-book-model-debug-v4";
    const groups: { title: string; controls: ControlConfig[] }[] = [
      {
        title: "整体",
        controls: [
          {
            key: "stageWidth",
            label: "舞台宽度",
            unit: "px",
            min: 240,
            max: 520,
            step: 1,
            value: 284,
            target: "stage",
            cssVar: "--debug-stage-width",
          },
          {
            key: "stageHeight",
            label: "舞台高度",
            unit: "px",
            min: 300,
            max: 680,
            step: 1,
            value: 480,
            target: "stage",
            cssVar: "--debug-stage-height",
          },
          {
            key: "offsetX",
            label: "水平位移",
            unit: "px",
            min: -120,
            max: 120,
            step: 1,
            value: 0,
            target: "model",
            cssVar: "--debug-model-x",
          },
          {
            key: "offsetY",
            label: "垂直位移",
            unit: "px",
            min: -120,
            max: 120,
            step: 1,
            value: 0,
            target: "model",
            cssVar: "--debug-model-y",
          },
          {
            key: "modelWidth",
            label: "封面宽度",
            unit: "px",
            min: 220,
            max: 380,
            step: 1,
            value: 284,
            target: "model",
            cssVar: "--model-width",
          },
          {
            key: "scale",
            label: "整体缩放",
            unit: "",
            min: 0.75,
            max: 1.15,
            step: 0.01,
            value: 0.96,
            target: "model",
            cssVar: "--model-scale",
          },
          {
            key: "skew",
            label: "封面斜切",
            unit: "deg",
            min: -16,
            max: 0,
            step: 0.1,
            value: -8,
            target: "model",
            cssVar: "--model-skew",
          },
        ],
      },
      {
        title: "封面图像",
        controls: [
          {
            key: "coverImageWidth",
            label: "图像宽度",
            unit: "%",
            min: 80,
            max: 125,
            step: 0.5,
            value: 100,
            target: "model",
            cssVar: "--debug-cover-image-width",
          },
          {
            key: "coverImageHeight",
            label: "图像高度",
            unit: "%",
            min: 80,
            max: 125,
            step: 0.5,
            value: 100,
            target: "model",
            cssVar: "--debug-cover-image-height",
          },
          {
            key: "coverImageX",
            label: "图像水平",
            unit: "px",
            min: -40,
            max: 40,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-cover-image-x",
          },
          {
            key: "coverImageY",
            label: "图像垂直",
            unit: "px",
            min: -40,
            max: 40,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-cover-image-y",
          },
        ],
      },
      {
        title: "封面框对齐",
        controls: [
          {
            key: "surfaceX",
            label: "封面框水平",
            unit: "px",
            min: -24,
            max: 24,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-surface-x",
          },
          {
            key: "surfaceY",
            label: "封面框垂直",
            unit: "px",
            min: -24,
            max: 24,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-surface-y",
          },
          {
            key: "surfaceWidth",
            label: "封面框宽度",
            unit: "%",
            min: 92,
            max: 108,
            step: 0.25,
            value: 100,
            target: "model",
            cssVar: "--debug-surface-width",
          },
          {
            key: "surfaceHeight",
            label: "封面框高度",
            unit: "%",
            min: 92,
            max: 108,
            step: 0.25,
            value: 100,
            target: "model",
            cssVar: "--debug-surface-height",
          },
        ],
      },
      {
        title: "书脊和页边",
        controls: [
          {
            key: "bookSize",
            label: "书脊厚度",
            unit: "px",
            min: 12,
            max: 56,
            step: 1,
            value: 28,
            target: "model",
            cssVar: "--book-size",
          },
          {
            key: "pagesHeight",
            label: "页边高度",
            unit: "px",
            min: 200,
            max: 360,
            step: 1,
            value: 273,
            target: "model",
            cssVar: "--model-pages-height",
          },
          {
            key: "pagesFine",
            label: "页边微调",
            unit: "px",
            min: -20,
            max: 28,
            step: 1,
            value: 10,
            target: "model",
            cssVar: "--model-pages-fine",
          },
          {
            key: "spineBrightness",
            label: "书脊亮度",
            unit: "",
            min: 0.5,
            max: 1,
            step: 0.01,
            value: 0.8,
            target: "model",
            cssVar: "--model-spine-brightness",
          },
          {
            key: "spineX",
            label: "书脊水平",
            unit: "px",
            min: -24,
            max: 24,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-spine-x",
          },
          {
            key: "spineY",
            label: "书脊垂直",
            unit: "px",
            min: -24,
            max: 24,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-spine-y",
          },
          {
            key: "spineHeight",
            label: "书脊高度",
            unit: "%",
            min: 94,
            max: 106,
            step: 0.25,
            value: 100,
            target: "model",
            cssVar: "--debug-spine-height",
          },
          {
            key: "pagesX",
            label: "顶页水平",
            unit: "px",
            min: -24,
            max: 24,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-pages-x",
          },
          {
            key: "pagesY",
            label: "顶页垂直",
            unit: "px",
            min: -36,
            max: 36,
            step: 0.5,
            value: 0,
            target: "model",
            cssVar: "--debug-pages-y",
          },
          {
            key: "pagesWidth",
            label: "顶页宽度",
            unit: "px",
            min: 16,
            max: 56,
            step: 0.5,
            value: 28,
            target: "model",
            cssVar: "--debug-pages-width",
          },
        ],
      },
      {
        title: "边框和阴影",
        controls: [
          {
            key: "border",
            label: "边框宽度",
            unit: "px",
            min: 0,
            max: 4,
            step: 0.5,
            value: 2,
            target: "model",
            cssVar: "--model-border",
          },
          {
            key: "radius",
            label: "外侧圆角",
            unit: "px",
            min: 0,
            max: 16,
            step: 1,
            value: 7,
            target: "model",
            cssVar: "--model-radius",
          },
          {
            key: "shadowHeight",
            label: "阴影高度",
            unit: "px",
            min: 0,
            max: 48,
            step: 1,
            value: 18,
            target: "model",
            cssVar: "--model-shadow-extra-height",
          },
          {
            key: "shadowWidth",
            label: "阴影宽度",
            unit: "px",
            min: 0,
            max: 48,
            step: 1,
            value: 8,
            target: "model",
            cssVar: "--model-shadow-extra-width",
          },
          {
            key: "shadowOffset",
            label: "阴影上移",
            unit: "px",
            min: -20,
            max: 40,
            step: 1,
            value: 8,
            target: "model",
            cssVar: "--model-shadow-offset",
          },
        ],
      },
    ];

    const flatControls = groups.flatMap((group) => group.controls);
    const saved = loadSaved();
    const values = Object.fromEntries(
      flatControls.map((control) => [
        control.key,
        saved[control.key] ?? control.value,
      ])
    ) as Record<string, number>;

    const controlsRoot = document.querySelector("[data-controls]");
    const output = document.querySelector("[data-output]") as HTMLTextAreaElement | null;
    const status = document.querySelector("[data-status]");
    const stage = document.querySelector("[data-debug-stage]") as HTMLElement | null;
    const model = document.querySelector(".book-cover--model") as HTMLElement | null;

    if (controlsRoot && stage && model) {
      renderControls(controlsRoot);
      applyValues();
      updateOutput();
    }

    document.querySelector("[data-action='reset']")?.addEventListener("click", () => {
      for (const control of flatControls) {
        values[control.key] = control.value;
      }
      syncInputs();
      applyValues();
      updateOutput("已恢复默认参数。");
    });

    document.querySelector("[data-action='clear']")?.addEventListener("click", () => {
      localStorage.removeItem(storageKey);
      updateOutput("已清除本地保存；当前页面参数仍保留。");
    });

    document.querySelector("[data-action='copy']")?.addEventListener("click", async () => {
      if (!output) return;
      await navigator.clipboard.writeText(output.value);
      updateStatus("已复制 CSS 参数。");
    });

    function renderControls(root: Element) {
      root.innerHTML = groups
        .map(
          (group) => `
            <section class="bmd-group">
              <h2>${group.title}</h2>
              ${group.controls.map(renderControl).join("")}
            </section>
          `
        )
        .join("");

      root.querySelectorAll<HTMLInputElement>("input[data-key]").forEach((input) => {
        input.addEventListener("input", () => {
          const key = input.dataset.key;
          if (!key) return;
          values[key] = Number(input.value);
          syncPair(key);
          applyValues();
          updateOutput();
        });
      });

      root.querySelectorAll<HTMLButtonElement>("button[data-reset-key]").forEach((button) => {
        button.addEventListener("click", () => {
          const key = button.dataset.resetKey;
          const control = flatControls.find((item) => item.key === key);
          if (!key || !control) return;
          values[key] = control.value;
          syncPair(key);
          applyValues();
          updateOutput(`${control.label}已重置。`);
        });
      });
    }

    function renderControl(control: ControlConfig) {
      const value = values[control.key];
      return `
        <div class="bmd-control">
          <span>${control.label}</span>
          <input
            type="range"
            data-key="${control.key}"
            data-kind="range"
            min="${control.min}"
            max="${control.max}"
            step="${control.step}"
            value="${value}"
          />
          <input
            type="number"
            data-key="${control.key}"
            data-kind="number"
            min="${control.min}"
            max="${control.max}"
            step="${control.step}"
            value="${value}"
            aria-label="${control.label}数值"
          />
          <button type="button" data-reset-key="${control.key}" aria-label="重置${control.label}">
            重置
          </button>
        </div>
      `;
    }

    function loadSaved() {
      try {
        return JSON.parse(localStorage.getItem(storageKey) ?? "{}") as Record<string, number>;
      } catch {
        return {};
      }
    }

    function syncInputs() {
      for (const control of flatControls) {
        syncPair(control.key);
      }
    }

    function syncPair(key: string) {
      document.querySelectorAll<HTMLInputElement>(`input[data-key="${key}"]`).forEach((input) => {
        input.value = String(values[key]);
      });
    }

    function applyValues() {
      for (const control of flatControls) {
        const target = control.target === "stage" ? stage : model;
        target?.style.setProperty(control.cssVar, formatValue(values[control.key], control.unit));
        if (control.cssVar === "--model-width") {
          stage?.style.setProperty(control.cssVar, formatValue(values[control.key], control.unit));
        }
      }
      localStorage.setItem(storageKey, JSON.stringify(values));
    }

    function updateOutput(message = "参数已更新并自动保存。") {
      if (!output) return;
      const lines = [
        ".bd-cover-stage {",
        `  height: ${values.stageHeight}px;`,
        `  width: ${values.stageWidth}px;`,
        "}",
        "",
        ".bd-cover-stage .book-cover--model {",
        ...flatControls
          .filter((control) => control.target === "model")
          .map(
            (control) =>
              `  ${control.cssVar}: ${formatValue(values[control.key], control.unit)};`
          ),
        "  transform:",
        `    translate(${values.offsetX}px, ${values.offsetY}px)`,
        "    skewY(var(--model-skew))",
        "    scale(var(--model-scale));",
        "  width: var(--model-width);",
        "}",
        "",
        ".bd-cover-stage .book-cover--model .book-cover-surface {",
        "  height: var(--debug-surface-height);",
        "  transform:",
        `    translate(${values.surfaceX}px, ${values.surfaceY}px);`,
        "  width: var(--debug-surface-width);",
        "}",
        "",
        ".bd-cover-stage .book-cover--model .book-cover-surface img {",
        "  height: var(--debug-cover-image-height);",
        "  max-width: none;",
        "  transform:",
        `    translate(${values.coverImageX}px, ${values.coverImageY}px);`,
        "  width: var(--debug-cover-image-width);",
        "}",
        "",
        ".bd-cover-stage .book-cover--model::after {",
        "  background-color: var(--model-spine-color);",
        "  background-image:",
        "    linear-gradient(rgb(0 0 0 / calc(1 - var(--model-spine-brightness))), rgb(0 0 0 / calc(1 - var(--model-spine-brightness)))),",
        "    var(--spine-texture, none);",
        "  background-position: 0 0, center;",
        "  background-size: 100% 100%, 100% 100%;",
        "  border: var(--model-border) solid rgb(0 0 0 / 0.18);",
        "  border-right: 0;",
        "  box-shadow: none;",
        "  height: var(--debug-spine-height);",
        "  left: calc(-1 * var(--book-size) + var(--debug-spine-x));",
        "  top: var(--debug-spine-y);",
        "  width: var(--book-size);",
        "}",
        "",
        ".bd-cover-stage .book-cover--model .book-cover-volume::before {",
        "  left: calc(-1 * var(--book-size) + var(--debug-pages-x));",
        "  top: calc(-1 * (var(--model-pages-height) - var(--model-border) + (var(--book-size) / 2)) + var(--model-pages-fine) + var(--debug-pages-y));",
        "  width: var(--debug-pages-width);",
        "}",
      ];
      output.value = lines.join("\n");
      updateStatus(message);
    }

    function updateStatus(message: string) {
      if (status) {
        status.textContent = message;
      }
    }

    function formatValue(value: number, unit: string) {
      return unit ? `${value}${unit}` : String(value);
    }
  </script>
</NewspaperLayout>
