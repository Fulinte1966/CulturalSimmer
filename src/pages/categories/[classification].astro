---
import Layout from "../../components/Layout.astro";
import { getClassificationNodes } from "../../lib/classification";

export async function getStaticPaths() {
  const nodes = getClassificationNodes();

  function collectCodes(nodeList: typeof nodes): string[] {
    const codes: string[] = [];
    for (const node of nodeList) {
      codes.push(node.code);
      codes.push(...collectCodes(node.children));
    }
    return codes;
  }

  return collectCodes(nodes).map((code) => ({
    params: { classification: code },
  }));
}
---

<Layout title="索引" activeNav="categories">
  <section class="reserved-page" aria-label="索引页待设计"></section>
</Layout>
