---
import {
  canOpenSiteUpdateDetail,
  formatSiteUpdateDateParts,
  type SiteFeedItem,
} from "../lib/siteUpdates";

interface Props {
  item: SiteFeedItem;
}

const { item } = Astro.props;
const dateParts = formatSiteUpdateDateParts(item.publishedAt);
---

<p class="fm-site-update-line">
  <span class="fm-site-update-meta">
    <time class="fm-site-update-date" datetime={item.publishedAt.toISOString()}>
      <span>{dateParts.year}</span>{" 年 "}
      <span class="fm-site-update-date-field">{dateParts.month}</span>{" 月 "}
      <span class="fm-site-update-date-field">{dateParts.day}</span>{" 日讯"}
    </time>
    <span>　［{item.label}］</span>
  </span>
  {canOpenSiteUpdateDetail(item) ? (
    <button
      type="button"
      class="fm-site-update-message fm-site-update-open"
      data-site-update-open={item.announcementId}
    >
      <span class="fm-site-update-message-text heti">{item.message}</span>
    </button>
  ) : (
    <span class="fm-site-update-message heti">{item.message}</span>
  )}
</p>
