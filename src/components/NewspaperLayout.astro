---
import "../styles/global.css";
import { joinBasePath } from "../lib/basePath";

interface Props {
  title: string;
  description?: string;
  searchable?: boolean;
}

const { title, description, searchable = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html
  lang="zh-CN"
  data-pagefind-ignore={searchable ? undefined : "all"}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - 文火</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={joinBasePath(base, "favicon.svg")} />
  </head>
  <body>
    <slot />
  </body>
</html>
