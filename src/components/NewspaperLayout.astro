---
import "../styles/global.css";
import BaseHead from "./BaseHead.astro";

interface Props {
  title: string;
  description?: string;
  searchable?: boolean;
}

const { title, description, searchable = false } = Astro.props;
---

<!doctype html>
<html
  lang="zh-CN"
  data-pagefind-ignore={searchable ? undefined : "all"}
>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <slot />
    <script>
      import "../scripts/cjk-spacing";
      import "../scripts/prevent-drag";
      import "../scripts/public-asset-fallback";
    </script>
  </body>
</html>
