---
import {
  formatDisplayCallNumber,
  formatEdition,
  formatEditionDateString,
  formatShortVolume,
} from "../lib/bookId";
import type { BookMeta } from "../lib/books";
import DownloadButton from "./DownloadButton.astro";
import ReadingStats from "./ReadingStats.astro";

interface Props {
  book: BookMeta;
}

const { book } = Astro.props;
---

<div class="detail-meta">
  <div class="meta-item">
    <span class="field-label">索书号</span>
    <span>{formatDisplayCallNumber(book.parsed)}</span>
  </div>
  {book.parsed.isVolume && (
    <div class="meta-item">
      <span class="field-label">册次</span>
      <span>{formatShortVolume(book.parsed.volumeNumber!, book.totalVolumes)}</span>
    </div>
  )}
  <div class="meta-item">
    <span class="field-label">版次</span>
    <span>
      {book.editionDate
        ? formatEditionDateString(book.editionDate, book.edition)
        : formatEdition(book.edition)}
    </span>
  </div>
  {book.editions.length > 1 && (
    <div class="meta-item">
      <span class="field-label">历次版次</span>
      <span>
        {book.editions
          .map((edition) => formatEditionDateString(edition.editionDate, edition.edition))
          .join("；")}
      </span>
    </div>
  )}
  {book.series && (
    <div class="meta-item">
      <span class="field-label">丛书</span>
      <span>{book.series}</span>
    </div>
  )}
  {book.publisher && (
    <div class="meta-item">
      <span class="field-label">出版者</span>
      <span>{book.publisher}</span>
    </div>
  )}
  {book.source && (
    <div class="meta-item">
      <span class="field-label">底本来源</span>
      <span>{book.source}</span>
    </div>
  )}
  {book.rights && (
    <div class="meta-item">
      <span class="field-label">权利说明</span>
      <span>{book.rights}</span>
    </div>
  )}
  {book.licenseUrl && (
    <div class="meta-item">
      <span class="field-label">许可</span>
      <a href={book.licenseUrl} rel="license">查看许可</a>
    </div>
  )}
</div>

<ReadingStats book={book} />

<div class="action-bar">
  <DownloadButton book={book} />
</div>
