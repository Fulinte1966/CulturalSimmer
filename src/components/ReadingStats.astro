---
import type { BookMeta } from "../lib/books";

interface Props {
  book: BookMeta;
  compact?: boolean;
}

const { book, compact = false } = Astro.props;
const characterCount =
  (book.reading?.cjkCharacterCount ?? 0) +
  (book.reading?.latinTokenCount ?? 0);
const hasStats =
  Boolean(book.reading?.pageCount) ||
  Boolean(characterCount) ||
  Boolean(book.reading?.estimatedMinutes);
---

{
  hasStats && (
    <ul class:list={["reading-stats", { "reading-stats--compact": compact }]}>
      {book.reading?.pageCount && <li>{book.reading.pageCount} 页</li>}
      {characterCount > 0 && (
        <li>约 {characterCount.toLocaleString("zh-CN")} 字</li>
      )}
      {book.reading?.estimatedMinutes && <li>约 {book.reading.estimatedMinutes} 分钟</li>}
    </ul>
  )
}
