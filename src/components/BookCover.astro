---
import type { BookMeta } from "../lib/books";
import { joinBasePath } from "../lib/basePath";

interface Props {
  book: BookMeta;
  mode?: "flat" | "model";
  pagefindMeta?: boolean;
}

const {
  book,
  mode = "flat",
  pagefindMeta = false,
} = Astro.props;
const coverClass = [
  "book-cover",
  `book-cover--${mode}`,
  `book-cover--${book.coverKind}`,
].join(" ");
const base = import.meta.env.BASE_URL;
const minModelThickness = 18;
const maxModelThickness = 42;
const fallbackModelThickness = 28;
const pageCount = book.reading?.pageCount;
const modelThickness =
  pageCount && Number.isFinite(pageCount)
    ? Math.min(
        maxModelThickness,
        Math.max(minModelThickness, Math.round(Math.sqrt(pageCount) * 1.9))
      )
    : fallbackModelThickness;
const modelStyle =
  mode === "model"
    ? [
        `--book-size: ${modelThickness}px`,
        `--pages-texture: url("${joinBasePath(base, "images/pages-texture.svg")}")`,
        book.spineUrl
          ? `--spine-texture: url("${book.spineUrl}")`
          : undefined,
      ]
        .filter(Boolean)
        .join("; ")
    : undefined;
---

<figure class={coverClass} style={modelStyle}>
  {mode === "model" && <span class="book-cover-shadow" aria-hidden="true" />}
  <div class="book-cover-volume">
    <div class="book-cover-surface">
      {
        book.coverUrl ? (
          <img
            src={book.coverUrl}
            alt={`${book.title}封面`}
            loading={mode === "flat" ? "lazy" : "eager"}
            data-pagefind-meta={
              pagefindMeta ? "image[src], image_alt[alt]" : undefined
            }
          />
        ) : (
          <div
            class="book-cover-placeholder"
            role="img"
            aria-label={`${book.title}排版封面`}
          >
            {book.author && (
              <span class="placeholder-author">{book.author}</span>
            )}
            <strong class="placeholder-title">{book.title}</strong>
            {book.subtitle && (
              <span class="placeholder-subtitle">{book.subtitle}</span>
            )}
          </div>
        )
      }
    </div>
  </div>
</figure>
