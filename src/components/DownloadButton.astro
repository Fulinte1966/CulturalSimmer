---
import { formatEdition } from "../lib/bookId";
import type { BookMeta } from "../lib/books";

interface Props {
  book: BookMeta;
}

const { book } = Astro.props;
---

<a
  href={book.downloadUrl}
  class="download-btn"
  target="_blank"
  rel="noopener noreferrer"
>
  下载 PDF（{formatEdition(book.edition)}）
</a>
