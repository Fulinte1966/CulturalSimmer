---
import "../styles/global.css";
import { joinBasePath } from "../lib/basePath";

export type ActiveNav = "new" | "search" | "categories" | "overview";

interface Props {
  title: string;
  description?: string;
  searchable?: boolean;
  activeNav: ActiveNav;
}

const { title, description, searchable = false, activeNav } = Astro.props;
const base = import.meta.env.BASE_URL;

const navItems: { id: ActiveNav; label: string; route: string }[] = [
  { id: "new", label: "新书", route: "/" },
  { id: "categories", label: "索引", route: "/categories/" },
  { id: "overview", label: "总览", route: "/books/" },
];
---

<!doctype html>
<html
  lang="zh-CN"
  data-pagefind-ignore={searchable ? undefined : "all"}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - 文火</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={joinBasePath(base, "favicon.svg")} />
  </head>
  <body>
    <header class="site-header" data-pagefind-ignore="all">
      <div class="inner site-header-inner">
        <a
          class="site-brand"
          href={base}
          aria-label="返回新书页"
        >
          <img
            src={joinBasePath(base, "brand/wordmark.svg")}
            alt="文火"
            width="100"
            height="43"
          />
        </a>
        <nav class="site-nav" aria-label="主导航">
          {
            navItems.map((item) => (
              <a
                href={joinBasePath(base, item.route)}
                aria-current={activeNav === item.id ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="inner">
        <slot />
      </div>
    </main>
  </body>
</html>
