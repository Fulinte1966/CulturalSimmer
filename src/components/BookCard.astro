---
import BookCover from "./BookCover.astro";
import type { BookMeta } from "../lib/books";
import { formatDisplayCallNumber } from "../lib/bookId";
import { joinBasePath } from "../lib/basePath";

interface Props {
  book: BookMeta;
}

const { book } = Astro.props;
const base = import.meta.env.BASE_URL;
const detailUrl = joinBasePath(base, `books/${book.id}/`);
---

<li class="catalog-item">
  <article>
    <a
      class="catalog-cover-link"
      href={detailUrl}
      aria-label={`查看《${book.title}》`}
    >
      <BookCover book={book} mode="flat" />
    </a>

    <p class="catalog-call-number">
      {formatDisplayCallNumber(book.parsed)}
    </p>

    <h3><a href={detailUrl}>{book.title}</a></h3>

    {book.subtitle && <p class="catalog-subtitle">{book.subtitle}</p>}

    {book.author && <p class="catalog-author">{book.author}</p>}
  </article>
</li>
