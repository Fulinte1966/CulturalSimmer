{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fulinte.pages.dev/CulturalSimmer/updates/feed.schema.json",
  "title": "CulturalSimmer public update feed",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "siteUrl", "updatesPageUrl", "updates"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "siteUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "updatesPageUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "updates": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "publishedAt", "title", "summary", "url"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9.-]+$" },
          "type": { "enum": ["new_book", "book_version", "important_erratum", "site_announcement"] },
          "publishedAt": { "type": "string", "format": "date-time" },
          "bookId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "version": { "type": "string", "pattern": "^v[1-9][0-9]*$" },
          "summary": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 240 }
          },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" }
        }
      }
    }
  }
}
